# Salin ke .env (lokal) atau set sebagai Environment Variables di hosting.

# Kunci rahasia session Flask — WAJIB diganti di produksi (string acak panjang).
SECRET_KEY=ganti-dengan-string-acak-panjang

# Koneksi database.
# - Kosongkan untuk pakai SQLite lokal (santuy.db).
# - Untuk PostgreSQL (Render/Railway), isi URL dari dashboard hosting, mis:
# DATABASE_URL=postgresql://user:password@host:5432/namadb
DATABASE_URL=
